model Cart {
  id        String   @id @default(cuid())
  userId    String
  items     CartItem[]
  user      User?    @relation(fields: [userId], references: [id])
}

//Single item in the cart, related to Cart
model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart?    @relation(fields: [cartId], references: [id])
  bookTitle String   @db.VarChar(255)
  quantity  Int      @db.Int
}
